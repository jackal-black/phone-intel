# ════════════════════════════════════════
# Phone Monitor — 环境变量配置
# 复制此文件为 .env 后填写
# ════════════════════════════════════════

# ── 搜索配置 ──
# 注册: https://app.tavily.com  → 免费 1000 次/月
TAVILY_API_KEY=your_tavily_api_key_here

# ── LLM 配置（任选一家，推荐 DeepSeek 性价比最高） ──
# DeepSeek:    https://api.deepseek.com/v1          | deepseek-chat
# OpenAI:      https://api.openai.com/v1             | gpt-4o-mini
# 通义千问:    https://dashscope.aliyuncs.com/compatible-mode/v1 | qwen-turbo
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ── 飞书推送配置 ──
# 飞书群 → 设置 → 群机器人 → 添加 Webhook 机器人
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_id

# ── 监控品牌（逗号分隔） ──
BRANDS=OPPO,vivo,华为,iPhone

# ── 运行模式 ──
# DRY_RUN=true  # 取消注释可启用仅打印模式（不推送飞书）
